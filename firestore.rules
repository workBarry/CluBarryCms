rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return hasProfile() && profile().role in ['Activity Leader', 'Vice President', 'Admin'];
    }

    function isAdmin() {
      return hasProfile() && profile().role == 'Admin';
    }

    match /users/{userId} {
      allow read: if isStaff() || signedIn() && request.auth.uid == userId;
      allow create: if isAdmin() || signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'Member';
      allow update: if isAdmin() || signedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['role', 'permissionsOverride']);
      allow delete: if isAdmin();
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isStaff() || signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if isStaff();
    }

    match /events/{eventId} {
      allow read: if resource.data.status == 'published' || isStaff();
      allow create: if isStaff()
        && request.resource.data.clubId is string
        && request.resource.data.title is string
        && request.resource.data.status in ['draft', 'published'];
      allow update: if isStaff()
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.currentCount == resource.data.currentCount;
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if resource.data.status == 'published' || isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if resource.data.status == 'open' || isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow read: if isStaff() || signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff() || signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isStaff() || signedIn() && resource.data.userId == request.auth.uid;
    }

    match /clubMembers/{memberId} {
      allow read: if isStaff() || signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isStaff() || signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.roleInClub == 'President'
        && get(/databases/$(database)/documents/clubs/$(request.resource.data.clubId)).data.createdBy
          == request.auth.uid;
      allow update, delete: if isStaff();
    }

    match /permissions/{role} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /permissionLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
